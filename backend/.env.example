PORT=3001
DATABASE_URL="postgresql://postgres:password@localhost:5432/viisync"
ASSISTANT_PERSISTENCE_PROVIDER="memory"
ASSISTANT_MEMORY_TTL_MS=86400000
ASSISTANT_MEMORY_MAX_CONVERSATIONS=100
MERCADOLIVRE_API_MODE="auto"
MERCADOLIVRE_API_BASE_URL="https://api.mercadolibre.com"
MERCADOLIVRE_AUTH_BASE_URL="https://auth.mercadolivre.com.br/authorization"
MERCADOLIVRE_OAUTH_TOKEN_URL="https://api.mercadolibre.com/oauth/token"
MERCADOLIVRE_CLIENT_ID=""
MERCADOLIVRE_CLIENT_SECRET=""
# Dev callback local. Em producao, use a URL publica do Railway.
MERCADOLIVRE_REDIRECT_URI="http://localhost:3001/integrations/mercadolivre/oauth/callback"
MERCADOLIVRE_ACCESS_TOKEN=""
MERCADOLIVRE_SELLER_ID=""
